PORT=5000
CLIENT_URL=http://localhost:5173
JWT_SECRET=change-me-in-production

# MongoDB Atlas: Atlas UI → Database → Connect → Drivers → Node.js.
# Paste your connection string; replace <password> with your database user password.
# Network Access: allow your current IP (or 0.0.0.0/0 only for temporary dev).
# Use /dbname at the end (before ?) for the database name, e.g. ...mongodb.net/vulnguard?retryWrites=true&w=majority
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster0.xxxxx.mongodb.net/vulnguard?retryWrites=true&w=majority

# If querySrv ECONNREFUSED: optional explicit DNS for SRV lookups (comma-separated)
# MONGODB_DNS_SERVERS=8.8.8.8,1.1.1.1
# Or leave unset — the API retries once with 8.8.8.8 / 1.1.1.1 automatically (disable with MONGODB_DNS_FALLBACK=0)

# Last resort: Atlas → Connect → Drivers → standard mongodb:// host list (no +srv), or fix VPN/DNS/firewall
