# Copy to `.env` locally — never commit `.env`.

# Frontend (Vite): browser → API base URL (must match your API)
VITE_API_URL=http://localhost:5000/api

# Backend (`npm run dev:backend` reads repo-root `.env` via dotenv paths)
PORT=5000
CLIENT_URL=http://localhost:5173
JWT_SECRET=change-me-in-production

# MongoDB Atlas — use placeholders only in shared templates; rotate DB user password if credentials were exposed.
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster0.xxxxx.mongodb.net/vulnguard?retryWrites=true&w=majority

# Optional: SRV DNS issues on Windows/networks — see shield-sme-api/.env.example
